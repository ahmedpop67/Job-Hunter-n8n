# =========================================================
# n8n Docker Compose Environment Variables
# Edit the values below before running `docker compose up -d`
# =========================================================
#ngrok http 5678
# ---- PostgreSQL ----
# =========================================================
# n8n Docker Compose Environment Variables
# Edit the values below before running `docker compose up -d`
# =========================================================
#ngrok http 5678
# ---- PostgreSQL ----
POSTGRES_USER=n8n
POSTGRES_PASSWORD=ahmedpop
POSTGRES_DB=n8n
# ---- n8n access ----
# If running purely locally, keep N8N_HOST=localhost and N8N_PROTOCOL=http
# If exposing via a domain/reverse proxy (recommended for real webhooks from
# online services), set your domain and https here instead.
N8N_HOST=slinky-diameter-pennant.ngrok-free.dev
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://slinky-diameter-pennant.ngrok-free.dev/
N8N_EDITOR_BASE_URL=https://slinky-diameter-pennant.ngrok-free.dev/
# Timezone (used for Cron/Schedule nodes)
GENERIC_TIMEZONE=Africa/Cairo
# ---- Basic auth for the n8n editor UI ----
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeMe_Str0ngPass!2026
# ---- Encryption key (used to encrypt stored credentials) ----
# Generate one with: openssl rand -hex 32
# IMPORTANT: back this up — losing it makes saved credentials unreadable.

N8N_ENCRYPTION_KEY=e247d682aab174e6917c793e8780cc7c3838075973dab8e8572394c835a9c7db
